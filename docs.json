{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Streamloop",
  "description": "Live stream pre-recorded videos to YouTube or any RTMP platform — 24/7, up to 4K 60fps. Cloud-based, no OBS, no PC required. Pay-per-use. Free credits to try.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "api": {
    "openapi": "https://api.streamloop.app/v1/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["bash", "python", "javascript"]
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "https://streamloop.app"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "quickstart",
              "features",
              "billing",
              "settings"
            ]
          },
          {
            "group": "Your first stream",
            "icon": "video",
            "expanded": true,
            "pages": [
              "upload-your-video-and-audio-playlist",
              "build-and-schedule-your-playlist",
              "set-up-your-destination",
              "get-your-stream-live"
            ]
          },
          {
            "group": "Guides",
            "icon": "lightbulb",
            "expanded": true,
            "pages": [
              "lofi-music-channel"
            ]
          },
          {
            "group": "Destinations",
            "icon": "radio",
            "expanded": true,
            "pages": [
              "platform/youtube",
              "platform/youtube-rtmp",
              "platform/twitch",
              "platform/facebook-live",
              "platform/kick",
              "platform/tiktok",
              "platform/instagram"
            ]
          },
          {
            "group": "Resources",
            "icon": "book-open",
            "pages": [
              "reliability-guarantees",
              "accepted-file-formats",
              "terms-of-service",
              "privacy-policy"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "icon": "terminal",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/conventions",
              "api-reference/quickstart"
            ]
          },
          {
            "group": "REST API",
            "icon": "code",
            "openapi": "https://api.streamloop.app/v1/openapi.json"
          },
          {
            "group": "MCP server",
            "icon": "bot",
            "expanded": true,
            "pages": [
              "api-reference/mcp/overview",
              "api-reference/mcp/tools"
            ]
          },
          {
            "group": "GraphQL API",
            "icon": "braces",
            "pages": [
              "api-reference/graphql"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/Group36.svg",
    "dark": "/images/logo-full-width-s7Ak8428.svg",
    "href": "https://streamloop.app"
  },
  "navbar": {
    "links": [
      {
        "href": "https://streamloop.app/#pricing",
        "label": "Pricing"
      },
      {
        "href": "https://streamloop.app/blog",
        "label": "Blog"
      },
      {
        "href": "https://streamloop.app/auth/login",
        "label": "Sign in"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://streamloop.app/loops"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/streamloopapp",
      "linkedin": "https://linkedin.com/company/streamloop",
      "github": "https://github.com/streamloopapp"
    }
  },
  "fonts": {
    "family": "Hanken Grotesk"
  },
  "background": {
    "color": {
      "dark": "#0D0D0E"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  }
}
